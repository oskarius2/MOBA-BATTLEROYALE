{
  "useSprites": true,
  "_comment": "Sprites enabled when baked PNGs pass dimension validation in sprite-sheet-manager.js. Re-run scripts/bake-art-sheets.py after replacing JPG sources.",
  "_spec": {
    "heroes": {
      "frameSize": 128,
      "framesPerAction": 6,
      "actionRows": 4,
      "minWidth": 768,
      "minHeight": 512,
      "rowLayout": ["idle", "walk", "attack", "transition"]
    },
    "hybrid": {
      "minHeight": 1024,
      "extraRows": 4,
      "stances": ["MELEE", "RANGED"],
      "note": "RANGED uses rows 4-7 (idle/walk/attack/transition)"
    },
    "creeps": {
      "frameSize": 96,
      "framesPerAction": 4,
      "actionRows": 4,
      "minWidth": 384,
      "minHeight": 384,
      "rowLayout": ["idle", "walk", "attack", "transition"]
    }
  },
  "heroes": {
    "Warrior": {
      "sheet": "heroes/warrior.png",
      "frameSize": 128,
      "framesPerAction": 6
    },
    "Mage": {
      "sheet": "heroes/mage.png",
      "frameSize": 128,
      "framesPerAction": 6
    },
    "Ranger": {
      "sheet": "heroes/ranger.png",
      "frameSize": 128,
      "framesPerAction": 6
    },
    "Tank-Viking": {
      "sheet": "heroes/viking.png",
      "frameSize": 128,
      "framesPerAction": 6
    },
    "Hybrid": {
      "sheet": "heroes/hybrid.png",
      "frameSize": 128,
      "framesPerAction": 6,
      "stances": ["MELEE", "RANGED"]
    }
  },
  "creeps": {
    "scout": {
      "sheet": "creeps/scout.png",
      "frameSize": 96,
      "framesPerAction": 4
    },
    "warrior": {
      "sheet": "creeps/warrior.png",
      "frameSize": 96,
      "framesPerAction": 4
    },
    "ancient": {
      "sheet": "creeps/ancient.png",
      "frameSize": 96,
      "framesPerAction": 4
    }
  }
}
